```{r}
library(tidyverse)
library(lubridate)

# Step 1. Filter for PM2.5 readings and clean structure
cinc_clean <- cinc_raw %>%
  filter(measure_name == "mc_pm2_5") %>%     # correct PM2.5 variable
  rename(
    datetime = time,
    pm25 = value,
    device = device_number
  ) %>%
  mutate(datetime = ymd_hms(datetime),
         date = as.Date(datetime))

# Step 2. Compute 24-hour average per device
cinc_daily_avg <- cinc_clean %>%
  group_by(device, date, location_name, latitude, longitude) %>%
  summarize(pm25_24hr_avg = mean(pm25, na.rm = TRUE), .groups = "drop")

# Step 3. Filter for Pair 3 (Devices 21 and 24)
cinc_pair3 <- cinc_daily_avg %>%
  filter(device %in% c(21, 24)) %>%
  arrange(device, date)

# Step 4. View results
print(cinc_pair3)

# Optional: Save to CSV for comparison with Jerry’s data
write_csv(cinc_pair3, "CinC_PM25_24hr_Pair3.csv")

```


