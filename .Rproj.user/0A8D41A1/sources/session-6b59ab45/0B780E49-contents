```{r}
# Load required libraries
library(tidyverse)
library(readxl)
library(lubridate)
library(ggplot2)

# STEP 1: Load your CinC PM2.5 24hr dataset
# Adjust this if you already loaded it into cinc_yours or cinc_pair3
# cinc_yours <- read_csv("CinC_PM25_24hr_Pair3_with_EUI.csv")

# STEP 2: Load Jerry's CinC 24hr dataset
jerry_cinc <- read_excel("daily_means_2024-11-01_to_2025-05-31.xls")

# STEP 3: Clean and prepare Jerry's data
jerry_clean <- jerry_cinc %>%
  rename(
    device_eui = device_eui,
    date = date_local,
    jerry_pm25 = pm25_mean
  ) %>%
  mutate(date = as.Date(date))

# STEP 4: Prepare your CinC data
your_clean <- cinc_yours %>%
  select(device_eui, date, your_pm25 = pm25_24hr_avg) %>%
  mutate(date = as.Date(date))

# STEP 5: Merge both datasets by date and device_eui
cinc_compare <- left_join(your_clean, jerry_clean, by = c("date", "device_eui")) %>%
  mutate(
    your_pm25 = as.numeric(your_pm25),
    jerry_pm25 = as.numeric(jerry_pm25)
  )

# STEP 6: Identify mismatches
cinc_compare <- cinc_compare %>%
  mutate(
    difference = abs(your_pm25 - jerry_pm25),
    match_status = ifelse(is.na(jerry_pm25) | is.na(your_pm25), "Missing",
                   ifelse(difference <= 2, "Match", "Mismatch"))
  )

# STEP 7: View mismatched values
mismatches <- cinc_compare %>% filter(match_status == "Mismatch")
print(mismatches)

# STEP 8: Plotting the comparison
ggplot(cinc_compare, aes(x = your_pm25, y = jerry_pm25, color = match_status)) +
  geom_point(size = 2, alpha = 0.8) +
  geom_abline(slope = 1, intercept = 0, linetype = "dashed", color = "gray40") +
  facet_wrap(~device_eui) +
  labs(
    title = "CinC PM2.5 24hr Avg: Regina vs Jerry",
    x = "Regina's PM2.5 (µg/m³)",
    y = "Jerry's PM2.5 (µg/m³)"
  ) +
  theme_minimal()

```

