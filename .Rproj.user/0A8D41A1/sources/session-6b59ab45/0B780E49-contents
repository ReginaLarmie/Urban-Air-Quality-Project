library(dplyr)

# Ensure numeric format
cinc_compare <- left_join(your_clean, jerry_clean, by = c("date", "device_eui")) %>%
  mutate(
    your_pm25 = as.numeric(your_pm25),
    jerry_pm25 = as.numeric(jerry_pm25),
    difference = abs(your_pm25 - jerry_pm25),
    match_status = case_when(
      is.na(your_pm25) | is.na(jerry_pm25) ~ "Missing",
      difference <= 2 ~ "Match",
      TRUE ~ "Mismatch"
    )
  )

# Create comparison table
comparison_table <- cinc_compare %>%
  select(device_eui, date, your_pm25, jerry_pm25, difference, match_status)

# View it in the RStudio Viewer or print the first few rows
