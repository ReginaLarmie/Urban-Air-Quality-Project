```{r}

# Load libraries
library(tidyverse)
library(lubridate)
library(dplyr)

# STEP 1: Load your CLEANinCLE data
cinc <- read_csv("CLEANinCLE_Raw_Air_Quality_Data_2024-11-2025-05.csv")

# STEP 2: Filter for Device 24 and just PM2.5 and time columns

device_24 <- cinc %>%
  filter(device_number == 24, measure_name == "mc_pm2_5") %>%
  select(time, pm25 = value) %>%
  mutate(time = ymd_hms(time)) %>%
  arrange(time)
# STEP 3: Calculate time gaps between readings
device_24 <- device_24 %>%
  mutate(time_diff_mins = as.numeric(difftime(time, lag(time), units = "mins")))

# STEP 4: Bin the time gaps
device_24 <- device_24 %>%
  mutate(gap_bin = cut(
    time_diff_mins,
    breaks = c(seq(0, 60, by = 5), Inf),
    labels = c("0-5", "5-10", "10-15", "15-20", "20-25", "25-30",
               "30-35", "35-40", "40-45", "45-50", "50-55", "55-60", ">60"),
    right = FALSE
  ))

# STEP 5: Plot the histogram
ggplot(device_24, aes(x = gap_bin)) +
  geom_bar(fill = "steelblue", color = "black") +
  labs(
    title = "Time Gaps Between PM2.5 Readings for Device 24",
    x = "Time Gap (minutes)",
    y = "Frequency"
  ) +
  theme_minimal() +
  theme(axis.text.x = element_text(angle = 45, hjust = 1))

```
```{r}

library(tidyverse)
library(lubridate)

# Filter PM2.5 for Device 24 and prepare data
device_24 <- cinc %>%
  filter(device_number == 24, measure_name == "mc_pm2_5") %>%
  select(time, pm25 = value) %>%
  mutate(time = ymd_hms(time)) %>%
  arrange(time) %>%
  mutate(time_diff_mins = as.numeric(difftime(time, lag(time), units = "mins"))) %>%
  filter(time_diff_mins <= 60) %>%  # Exclude gaps > 60 min
  mutate(gap_bin = cut(
    time_diff_mins,
    breaks = c(seq(0, 60, by = 5)),
    labels = c("0–5", "5–10", "10–15", "15–20", "20–25", "25–30",
               "30–35", "35–40", "40–45", "45–50", "50–55", "55–60"),
    right = FALSE
  ))

# Calculate bin counts and mode
gap_counts_24 <- device_24 %>%
  count(gap_bin, name = "count") %>%
  filter(!is.na(gap_bin))

mode_bin_24 <- gap_counts_24 %>%
  filter(count == max(count)) %>%
  pull(gap_bin) %>%
  as.character()

# Map bin label to midpoint for the vertical line
bin_midpoints <- c(
  "0–5" = 2.5, "5–10" = 7.5, "10–15" = 12.5, "15–20" = 17.5,
  "20–25" = 22.5, "25–30" = 27.5, "30–35" = 32.5, "35–40" = 37.5,
  "40–45" = 42.5, "45–50" = 47.5, "50–55" = 52.5, "55–60" = 57.5
)
mode_x_24 <- bin_midpoints[mode_bin_24]

# Plot
ggplot(gap_counts_24, aes(x = gap_bin, y = count)) +
  geom_bar(stat = "identity", fill = "orange", color = "black") +
  geom_text(aes(label = count), vjust = -0.5, size = 3.5) +
  geom_vline(xintercept = which(levels(gap_counts_24$gap_bin) == mode_bin_24),
             linetype = "dashed", color = "red", linewidth = 1) +
  annotate("text", x = which(levels(gap_counts_24$gap_bin) == mode_bin_24),
           y = max(gap_counts_24$count) + 100,
           label = paste0("Most frequent: ", mode_x_24, " min"),
           color = "red", hjust = 0.5, size = 4.2) +
  labs(
    title = "Time Gaps Between PM2.5 Readings for Device 24",
    x = "Time Gap (minutes)",
    y = "Frequency"
  ) +
  theme_minimal() +
  theme(axis.text.x = element_text(angle = 45, hjust = 1))
```

