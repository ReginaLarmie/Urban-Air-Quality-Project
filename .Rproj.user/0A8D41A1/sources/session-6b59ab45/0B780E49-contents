```{r}
library(dplyr)
library(ggplot2)
library(lubridate)

# Filter for Device 7 and select only PM2.5 readings
device_7 <- cinc %>%
  filter(device_number == 7, measure_name == "mc_pm2_5") %>%
  mutate(time = ymd_hms(time)) %>%
  arrange(time)

# Calculate time gaps between consecutive readings (in minutes)
device_7 <- device_7 %>%
  mutate(time_gap = as.numeric(difftime(time, lag(time), units = "mins"))) %>%
  filter(!is.na(time_gap))

# Cap gaps > 60 min to NA (to exclude from plot)
filtered_gaps <- device_7 %>%
  filter(time_gap <= 60)

# Create histogram
hist_plot <- ggplot(filtered_gaps, aes(x = time_gap)) +
  geom_histogram(
    breaks = seq(0, 60, by = 5),
    fill = "#4c72b0",
    color = "black",
    closed = "left"
  ) +
  labs(
    title = "Time Gaps Between PM2.5 Readings for Device 7",
    x = "Time Gap (minutes)",
    y = "Frequency"
  ) +
  theme_minimal()

# Calculate mode (most frequent time gap bin)
gap_counts <- hist(filtered_gaps$time_gap, breaks = seq(0, 60, 5), plot = FALSE)
mode_bin <- gap_counts$mids[which.max(gap_counts$counts)]

# Add vertical line at mode and label it
hist_plot + 
  geom_vline(xintercept = mode_bin, color = "red", linetype = "dashed", size = 1) +
  annotate("text", x = mode_bin + 1.5, y = max(gap_counts$counts), 
           label = paste("Most frequent:", mode_bin, "min"), 
           color = "red", hjust = 0, size = 4) +
  stat_bin(
    breaks = seq(0, 60, 5),
    geom = "text",
    aes(label = ..count..),
    vjust = -0.5,
    size = 3
  )

