# Step 4: Remove duplicates in measurements by averaging
epa_data_clean <- epa_data %>%
  select(site_number, date, pm25 = sample_measurement) %>%
  group_by(site_number, date) %>%
  summarise(pm25 = mean(pm25, na.rm = TRUE), .groups = "drop")

# Step 5: Pivot to wide format for R² calculation
epa_wide <- epa_data_clean %>%
  pivot_wider(names_from = site_number, values_from = pm25)

# Step 6: Function to calculate R²
get_r2 <- function(a, b) {
  if (!(a %in% colnames(epa_wide)) || !(b %in% colnames(epa_wide))) return(NA)
  x <- epa_wide[[a]]
  y <- epa_wide[[b]]
  if (all(is.na(x)) || all(is.na(y))) return(NA)
  df <- data.frame(x = x, y = y) %>% na.omit()
  if (nrow(df) < 10) return(NA)
  model <- lm(y ~ x, data = df)
  summary(model)$r.squared
}

# Step 7: Calculate R² for all site pairs
site_pairs$r_squared <- mapply(get_r2, site_pairs$site_a, site_pairs$site_b)

# Step 8: Create final 4-column dataset
site_pairs_final <- site_pairs %>%
  select(site_a, site_b, r_squared, distance_km)

# Step 9: Save as CSV and view
write_csv(site_pairs_final, "epa_site_pairwise_r2_distance.csv")
View(site_pairs_final)
