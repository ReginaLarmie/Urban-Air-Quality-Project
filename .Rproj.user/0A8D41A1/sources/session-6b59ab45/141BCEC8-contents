# Load libraries
library(dplyr)
library(tidyr)
library(purrr)
library(readr)
library(geosphere)
library(ggplot2)
library(ggrepel)

# Step 1: Pivot EPA data to wide format
epa_wide <- epa_all_data %>%
  select(site_number, date_local, sample_measurement) %>%
  pivot_wider(names_from = site_number, values_from = sample_measurement)

# Step 2: Drop rows with too many NAs
epa_wide <- epa_wide %>%
  filter(rowSums(is.na(.)) < ncol(.) - 2)

# Step 3: Get unique site names (column names excluding date)
site_names <- setdiff(colnames(epa_wide), "date_local")

# Step 4: Create all unique site pairs
site_pairs_list <- combn(site_names, 2, simplify = FALSE)

# Step 5: Function to calculate R-squared
get_r2 <- function(site1, site2, df) {
  df_pair <- df %>% select(all_of(c(site1, site2))) %>% drop_na()
  if (nrow(df_pair) < 10) return(NA)  # skip if not enough data
  model <- lm(df_pair[[site2]] ~ df_pair[[site1]])
  summary(model)$r.squared
}

# Step 6: Apply function to each pair
r2_results <- map_dfr(site_pairs_list, function(pair) {
  tibble(
    site_a = pair[1],
    site_b = pair[2],
    r_squared = get_r2(pair[1], pair[2], epa_wide)
  )
})

# Step 7: Add distances to each site pair (assuming you already have site_pairs with lat/lon)
site_pairs_final <- site_pairs %>%
  left_join(r2_results, by = c("site_a", "site_b")) %>%
  mutate(label = paste(site_a, site_b, sep = "-"))

# Step 8: Plot
ggplot(site_pairs_final, aes(x = distance_km, y = r_squared)) +
  geom_point(color = "#2c7fb8", size = 3) +
  geom_text_repel(aes(label = label), size = 3, max.overlaps = 15) +
  geom_smooth(method = "lm", se = FALSE, color = "darkred", linetype = "dashed") +
  labs(
    title = "R² vs. Distance Between EPA Sites",
    x = "Distance (km)",
    y = expression(R^2)
  ) +
  theme_minimal(base_size = 14)

