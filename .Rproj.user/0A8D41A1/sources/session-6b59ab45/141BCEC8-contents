```{r}
library(dplyr)
library(readr)
library(tidyr)
library(geosphere)

# Step 1: Read in the EPA dataset with PM2.5 values and coordinates
epa_data <- read_csv("epa_pm25_site_combined.csv")

# Step 2: Create all pairwise combinations (including self-pairs)
epa_sites <- epa_data %>%
  select(site_number, latitude, longitude) %>%
  distinct()

site_pairs <- expand_grid(site_a = epa_sites$site_number, site_b = epa_sites$site_number)

# Step 3: Join coordinates for both sites in the pair
site_pairs <- site_pairs %>%
  left_join(epa_sites, by = c("site_a" = "site_number")) %>%
  rename(lat_a = latitude, lon_a = longitude) %>%
  left_join(epa_sites, by = c("site_b" = "site_number")) %>%
  rename(lat_b = latitude, lon_b = longitude)

# Step 4: Compute distance between each pair (in km)
site_pairs <- site_pairs %>%
  mutate(distance_km = distHaversine(cbind(lon_a, lat_a), cbind(lon_b, lat_b)) / 1000)

# Step 5: Compute R-squared for each pair using daily PM2.5 data
epa_data <- epa_data %>% mutate(date = as.Date(date_local))

# Create a wide-format dataset for PM2.5 values by site and date
epa_wide <- epa_data %>%
  select(site_number, date, pm25 = sample_measurement) %>%
  pivot_wider(names_from = site_number, values_from = pm25)

# Function to calculate R-squared between two numeric vectors
get_r2 <- function(x, y) {
  if (all(is.na(x)) || all(is.na(y))) return(NA)
  model <- lm(y ~ x)
  summary(model)$r.squared
}

# Loop over each pair and compute R²
site_pairs$r_squared <- mapply(function(a, b) {
  if (a %in% colnames(epa_wide) && b %in% colnames(epa_wide)) {
    get_r2(epa_wide[[a]], epa_wide[[b]])
  } else {
    NA
  }
}, site_pairs$site_a, site_pairs$site_b)

# Step 6: Save results
write_csv(site_pairs, "epa_site_pairwise_r2_distance.csv")
View(site_pairs)


