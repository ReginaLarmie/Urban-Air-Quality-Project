```{r}
# 7. Build the combined CinC ↔ EPA tables (with concentrations)

We’ll make **three** concentration tables your advisor can open in Excel:

1) CinC vs **EPA Continuous (FEM)** (all overlapping days)  
2) CinC vs **EPA Continuous on FRM days** (subset)  
3) CinC vs **EPA FRM (24‑hr)**

Each table has real PM₂.₅ values per day, per device, per paired EPA site.

```r
```{r cinc-epa-joins}
# Convenience for joins
cinc_daily_map <- cinc_daily %>%
  left_join(device_to_epa, by = "device_number")

# A) CinC vs EPA Continuous (FEM → daily)
tbl_cinc_vs_epa_cont <- cinc_daily_map %>%
  inner_join(epa_fem_daily, by = c("epa_site" = "Site", "date" = "Date")) %>%
  transmute(
    Site          = epa_site,
    Date          = date,
    device_number,
    PM25_CinC     = pm25_cinc,
    PM25_EPA_FEM  = PM25_FEM
  ) %>%
  arrange(Site, Date, device_number)

# B) CinC vs EPA Continuous on FRM days only
frm_dates <- epa_24hr_daily %>% distinct(Date)

tbl_cinc_vs_epa_cont_on_frm <- cinc_daily_map %>%
  inner_join(
    epa_fem_daily %>% semi_join(frm_dates, by = "Date"),
    by = c("epa_site" = "Site", "date" = "Date")
  ) %>%
  transmute(
    Site          = epa_site,
    Date          = date,
    device_number,
    PM25_CinC     = pm25_cinc,
    PM25_EPA_FEM  = PM25_FEM
  ) %>%
  arrange(Site, Date, device_number)

# C) CinC vs EPA FRM (24‑hr)
tbl_cinc_vs_epa_frm <- cinc_daily_map %>%
  inner_join(epa_24hr_daily, by = c("epa_site" = "Site", "date" = "Date")) %>%
  transmute(
    Site          = epa_site,
    Date          = date,
    device_number,
    PM25_CinC     = pm25_cinc,
    PM25_EPA_FRM  = PM25_FRM
  ) %>%
  arrange(Site, Date, device_number)

# Save all three concentration tables
write_csv(tbl_cinc_vs_epa_cont,        "tables/cinc_vs_epa_cont_daily.csv")
write_csv(tbl_cinc_vs_epa_cont_on_frm, "tables/cinc_vs_epa_cont_on_frm_days.csv")
write_csv(tbl_cinc_vs_epa_frm,         "tables/cinc_vs_epa_frm_24hr.csv")

# Quick peek
head(tbl_cinc_vs_epa_cont)
head(tbl_cinc_vs_epa_cont_on_frm)
head(tbl_cinc_vs_epa_frm)
```



```{r}
# 8. Add per-site R² summaries for the CinC ↔ EPA tables

These summaries (by site) align with what your advisor wants to verify in Excel.

```r
```{r cinc-epa-r2-summaries}
per_site_stats <- function(df, x_name, y_name, site_name = "Site") {
  df %>%
    filter(is.finite(.data[[x_name]]), is.finite(.data[[y_name]])) %>%
    group_by(.data[[site_name]]) %>%
    summarise(
      n         = n(),
      slope     = if (n() > 2) coef(lm(.data[[y_name]] ~ .data[[x_name]]))[2] else NA_real_,
      intercept = if (n() > 2) coef(lm(.data[[y_name]] ~ .data[[x_name]]))[1] else NA_real_,
      r2        = if (n() > 2) summary(lm(.data[[y_name]] ~ .data[[x_name]]))$r.squared else NA_real_,
      .groups   = "drop"
    ) %>%
    rename(Site = 1)
}

# R² tables (by Site)
r2_cinc_vs_fem         <- per_site_stats(tbl_cinc_vs_epa_cont,        "PM25_EPA_FEM", "PM25_CinC")
r2_cinc_vs_fem_on_frm  <- per_site_stats(tbl_cinc_vs_epa_cont_on_frm, "PM25_EPA_FEM", "PM25_CinC")
r2_cinc_vs_frm         <- per_site_stats(tbl_cinc_vs_epa_frm,         "PM25_EPA_FRM", "PM25_CinC")

# add suggested common axes (optional)
suggest_axes <- function(x, y) {
  lim_hi <- quantile(c(x, y), 0.995, na.rm = TRUE)
  c(0, max(5, ceiling(lim_hi/5)*5))
}
lims1 <- suggest_axes(tbl_cinc_vs_epa_cont$PM25_EPA_FEM,        tbl_cinc_vs_epa_cont$PM25_CinC)
lims2 <- suggest_axes(tbl_cinc_vs_epa_cont_on_frm$PM25_EPA_FEM, tbl_cinc_vs_epa_cont_on_frm$PM25_CinC)
lims3 <- suggest_axes(tbl_cinc_vs_epa_frm$PM25_EPA_FRM,         tbl_cinc_vs_epa_frm$PM25_CinC)

r2_cinc_vs_fem        <- r2_cinc_vs_fem        %>% mutate(axis_min = lims1[1], axis_max = lims1[2])
r2_cinc_vs_fem_on_frm <- r2_cinc_vs_fem_on_frm %>% mutate(axis_min = lims2[1], axis_max = lims2[2])
r2_cinc_vs_frm        <- r2_cinc_vs_frm        %>% mutate(axis_min = lims3[1], axis_max = lims3[2])

# Save summaries
write_csv(r2_cinc_vs_fem,        "tables/summary_cinc_vs_epa_cont_r2.csv")
write_csv(r2_cinc_vs_fem_on_frm, "tables/summary_cinc_vs_epa_cont_on_frm_r2.csv")
write_csv(r2_cinc_vs_frm,        "tables/summary_cinc_vs_epa_frm_r2.csv")

r2_cinc_vs_fem
```




