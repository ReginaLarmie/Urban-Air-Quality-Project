  rowwise() %>%
  mutate(
    distance_m = geosphere::distHaversine(
      c(EPA_Lon, EPA_Lat),
      c(CinC_Lon, CinC_Lat)
    )
  ) %>%
  ungroup() %>%
  mutate(distance_km = distance_m / 1000)

