# --- Make one CinC-vs-EPA Continuous plot for EVERY EPA site (nearest CinC device with overlap) ---

library(tidyverse)
library(geosphere)
library(glue)
library(gridExtra)   # for the combined grid

# Paths created earlier in your workflow
tbl_path        <- "tables/cinc_vs_epa_cont_daily.csv"   # Date, Site, device_number, PM25_CinC, PM25_EPA_FEM
cinc_loc_path   <- "tables/cinc_device_locations.csv"    # device_number, latitude, longitude, ...
epa_coords_path <- "tables/epa_site_coords.csv"          # Site, Latitude, Longitude

# Read tables
df_all   <- readr::read_csv(tbl_path,        show_col_types = FALSE)
cinc_loc <- readr::read_csv(cinc_loc_path,   show_col_types = FALSE) %>%
  mutate(device_number = as.character(device_number))
epa_loc  <- readr::read_csv(epa_coords_path, show_col_types = FALSE)

# Helper to pick nearest CinC device **that has overlap** with a given EPA site
nearest_device_with_overlap <- function(site_id) {
  # devices that actually have days overlapping this site (guarantees the plot will have points)
  devs_with_overlap <- df_all %>%
    filter(Site == site_id) %>%
    distinct(device_number) %>%
    pull(device_number)

  if (length(devs_with_overlap) == 0) return(NULL)

  # coords for the EPA site
  epa_row <- epa_loc %>% filter(Site == site_id) %>% slice(1)
  if (nrow(epa_row) == 0) return(NULL)

  # compute distance to each overlapping device
  cand <- cinc_loc %>%
    filter(device_number %in% devs_with_overlap) %>%
    mutate(
      dist_km = geosphere::distHaversine(
        cbind(epa_row$Longitude, epa_row$Latitude),
        cbind(longitude, latitude)
      ) / 1000
    ) %>%
    arrange(dist_km)

  if (nrow(cand) == 0) return(NULL)
  cand %>% slice(1) %>% select(device_number, dist_km)
}

# Plot function for one site
plot_one_site <- function(site_id, axis_cap = 100) {
  pick <- nearest_device_with_overlap(site_id)
  if (is.null(pick)) return(NULL)

  dev_id  <- pick$device_number[1]
  dist_km <- pick$dist_km[1]

  # data for that pair
  d <- df_all %>% filter(Site == site_id, device_number == dev_id)
  if (nrow(d) == 0) return(NULL)

  # axis limits (cap at 100 by default, or extend if needed)
  axis_max <- max(axis_cap,
                  ceiling(max(d$PM25_EPA_FEM, d$PM25_CinC, na.rm = TRUE)/10) * 10)
  lims <- c(0, axis_max)

  # regression bits
  if (nrow(d) > 2) {
    fit <- lm(PM25_CinC ~ PM25_EPA_FEM, data = d)
    slope <- unname(coef(fit)[2]); intercept <- unname(coef(fit)[1])
    r2    <- summary(fit)$r.squared
    lab   <- glue("y = {formatC(slope, format='f', digits=2)}x {formatC(intercept, format='f', digits=2, flag='+')}\nR² = {formatC(r2, format='f', digits=2)}")
  } else {
    lab <- "n < 3"
  }

  site_short <- sub("^0+", "", site_id)
  subtitle   <- glue("{format(dist_km, digits = 3, nsmall = 3)} km apart",
                     if (dist_km <= 0.05) " (co-located)" else "")

  ggplot(d, aes(PM25_EPA_FEM, PM25_CinC)) +
    geom_point(alpha = 0.8, size = 2.2) +
    geom_smooth(method = "lm", se = FALSE, linewidth = 1, color = "steelblue") +
    geom_abline(slope = 1, intercept = 0, color = "hotpink", linewidth = 1) +
    coord_cartesian(xlim = lims, ylim = lims, expand = FALSE) +
    annotate("text",
             x = lims[1] + diff(lims)*0.03,
             y = lims[2] - diff(lims)*0.06,
             hjust = 0, vjust = 1, size = 4, label = lab) +
    labs(
      subtitle = subtitle,
      x = glue("PM2.5 EPA Continuous - Site {site_short} (µg/m³)"),
      y = glue("PM2.5 CinC Dev {dev_id} (µg/m³)")
    ) +
    theme_minimal(base_size = 13) +
    theme(
      panel.grid.minor = element_blank(),
      plot.title = element_text(face = "bold")
    )
}

# Make and save one plot per site + a summary table of which device was used
dir.create("figs", showWarnings = FALSE)

all_sites <- sort(unique(df_all$Site))
