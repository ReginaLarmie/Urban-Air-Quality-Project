```{r}
# 2. Load EPA data (all sites)

> We’ll read each EPA CSV, tag it with the site id, and keep only columns we need.

```r
```{r epa-load}
# List of EPA site IDs you have files for (update if needed)
epa_sites <- c("0034","0038","0045","0060","0065","0073")

# Helper to read one site file (expects files like: epa_pm25_site_0034.csv)
read_epa_site <- function(site_id){
  f <- sprintf("epa_pm25_site_%s.csv", site_id)
  stopifnot(file.exists(f))
  read_csv(f, show_col_types = FALSE) %>%
    mutate(site_number = site_id)
}

epa_all <- map_dfr(epa_sites, read_epa_site)

# Keep the essentials and standardize names
epa_all <- epa_all %>%
  transmute(
    Site         = site_number,
    DateTime     = ymd_hms(date_local, quiet = TRUE),  # if already date, it still works
    Date         = as.Date(date_local),
    SampleDur    = sample_duration,
    PM25         = sample_measurement,
    Latitude     = latitude,
    Longitude    = longitude
  )

glimpse(epa_all)
```


```{r}
# 3. Build daily EPA tables (FRM and FEM) + site coordinates

```r
```{r epa-dailies}
# Daily FRM (24-hr)
epa_24hr_daily <- epa_all %>%
  filter(SampleDur == "24 HOUR") %>%
  group_by(Site, Date) %>%
  summarise(PM25_FRM = mean(PM25, na.rm = TRUE), .groups = "drop")

# Daily FEM (1-hr aggregated to daily mean)
epa_fem_daily <- epa_all %>%
  filter(SampleDur == "1 HOUR") %>%
  group_by(Site, Date) %>%
  summarise(PM25_FEM = mean(PM25, na.rm = TRUE), .groups = "drop")

# Site coordinates (mean of all records per site)
epa_coords <- epa_all %>%
  group_by(Site) %>%
  summarise(
    Latitude  = mean(Latitude,  na.rm = TRUE),
    Longitude = mean(Longitude, na.rm = TRUE),
    .groups = "drop"
  )

# Save tables with the actual concentrations
write_csv(epa_24hr_daily, "tables/epa_24hr_daily.csv")
write_csv(epa_fem_daily,  "tables/epa_fem_daily.csv")
write_csv(epa_coords,     "tables/epa_site_coords.csv")

# Quick peek
head(epa_24hr_daily); head(epa_fem_daily); epa_coords
```



```{r}
# 4. EPA FEM vs FRM – combined table (per-day, per-site) + per-site R²

> This is the **exact table** your advisor wants to be able to audit the plots: one row per site‑day with both FRM and FEM concentrations.

```r
```{r epa-fem-vs-frm-tables}
# Put PM25_FEM and PM25_FRM on the same row
epa_fem_vs_frm <- inner_join(
  epa_fem_daily,      # Date, Site, PM25_FEM
  epa_24hr_daily,     # Date, Site, PM25_FRM
  by = c("Date","Site")
) %>%
  arrange(Site, Date)

# Save the combined table with concentrations
write_csv(epa_fem_vs_frm, "tables/epa_fem_vs_frm_daily.csv")

# Per-site regression stats (slope, intercept, R², n)
epa_fem_vs_frm_stats <- epa_fem_vs_frm %>%
  group_by(Site) %>%
  summarise(
    n         = n(),
    slope     = if (n() > 2) coef(lm(PM25_FEM ~ PM25_FRM))[2] else NA_real_,
    intercept = if (n() > 2) coef(lm(PM25_FEM ~ PM25_FRM))[1] else NA_real_,
    r2        = if (n() > 2) summary(lm(PM25_FEM ~ PM25_FRM))$r.squared else NA_real_,
    .groups = "drop"
  )

# Common axis suggestion used in plots (optional convenience)
lim_hi <- quantile(c(epa_fem_vs_frm$PM25_FEM, epa_fem_vs_frm$PM25_FRM), 0.995, na.rm = TRUE)
lims   <- c(0, max(5, ceiling(lim_hi/5)*5))
epa_fem_vs_frm_stats <- epa_fem_vs_frm_stats %>%
  mutate(axis_min = lims[1], axis_max = lims[2])

write_csv(epa_fem_vs_frm_stats, "tables/summary_epa_fem_vs_frm_r2.csv")

# Quick peek
head(epa_fem_vs_frm); epa_fem_vs_frm_stats
```


```{r}
# 5. CLEANinCLE (CinC) data → daily averages + device locations

```r
```{r cinc-load-daily}
# UPDATE the path to your raw file:
cinc_path <- "CLEANinCLE_Raw_Air_Quality_Data_2024-11-2025-05.csv"
stopifnot(file.exists(cinc_path))

cinc_raw <- read_csv(cinc_path, show_col_types = FALSE) %>%
  janitor::clean_names()

# Keep PM2.5 and normalize fields
cinc_pm <- cinc_raw %>%
  filter(measure_name %in% c("pm25","pm2.5","mc_pm2_5")) %>%
  mutate(
    datetime = ymd_hms(time, quiet = TRUE),
    date     = as.Date(datetime)
  ) %>%
  transmute(
    device_number = as.character(device_number),
    date,
    pm25 = value,
    latitude, longitude,
    device_eui, location_name
  )

# Device locations
cinc_locations <- cinc_pm %>%
  distinct(device_number, device_eui, location_name, latitude, longitude)

# Daily average per device
cinc_daily <- cinc_pm %>%
  group_by(device_number, date) %>%
  summarise(pm25_cinc = mean(pm25, na.rm = TRUE), .groups = "drop")

# Save with concentrations
write_csv(cinc_locations, "tables/cinc_device_locations.csv")
write_csv(cinc_daily,     "tables/cinc_daily_pm25.csv")

head(cinc_daily)
