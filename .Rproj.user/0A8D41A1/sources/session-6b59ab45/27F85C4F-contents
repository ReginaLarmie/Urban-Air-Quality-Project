```{r}
library(dplyr)
library(lubridate)

# helpers
f_to_c <- function(f) (f - 32) * 5/9

rh_from_t_td <- function(Tc, TDc) {
  es  <- 6.112 * exp((17.67 * Tc)  / (Tc  + 243.5))
  esd <- 6.112 * exp((17.67 * TDc) / (TDc + 243.5))
  100 * (esd / es)
}

circ_mean_deg <- function(deg) {
  deg <- deg[!is.na(deg)]
  if (length(deg) == 0) return(NA_real_)
  rad <- deg * pi/180
  m <- atan2(mean(sin(rad)), mean(cos(rad))) * 180/pi
  if (m < 0) m <- m + 360
  m
}

df_30min <- df %>%
  mutate(
    temp_c = f_to_c(tmpf),
    dew_c  = f_to_c(dwpf),
    rh = rh_from_t_td(temp_c, dew_c),
    # 30-minute bins in UTC
    t30 = floor_date(datetime_utc, unit = "30 minutes")
  ) %>%
  group_by(t30) %>%
  summarise(
    station = first(station),
    station_name = first(station_name),
    temp_c_mean = mean(temp_c, na.rm = TRUE),
    rh_mean = mean(rh, na.rm = TRUE),
    wind_spd_kn_mean = mean(sknt, na.rm = TRUE),
    wind_dir_deg_mean = circ_mean_deg(drct),
    n_1min = sum(!is.na(datetime_utc)),
    .groups = "drop"
  ) %>%
  arrange(t30)

# save it
out_30 <- file.path(out_dir, sprintf("ASOS1min_%s_%s_Jan_30min_core.csv", station3, year))
readr::write_csv(df_30min, out_30)
out_30
