# Burke Lakefront 2024 data
```{r}
library(httr)
library(readr)


station <- "BKL"   # Burke Lakefront (KBKL)
year <- 2024

vars <- c("tmpf","dwpf","sknt","drct","ptype","precip")
base_url <- "https://mesonet.agron.iastate.edu/cgi-bin/request/asos1min.py"

out_dir <- "ASOS_1min_2024_raw_BKL"
dir.create(out_dir, showWarnings = FALSE, recursive = TRUE)


# Helper: make month start/end timestamps in UTC

month_window <- function(year, month) {
  start <- as.POSIXct(sprintf("%d-%02d-01 00:00:00", year, month), tz = "UTC")
  end   <- start %m+% months(1)
  list(
    sts = format(start, "%Y-%m-%dT%H:%MZ"),
    ets = format(end,   "%Y-%m-%dT%H:%MZ")
  )
}

# lubridate needed for %m+% months(1)
library(lubridate)

# Loop over months

for (m in 1:12) {

  w <- month_window(year, m)

  query_list <- c(
    list(
      station = station,
      sts = w$sts,
      ets = w$ets,
      sample = "1min",
      what = "download",
      tz = "UTC"
    ),
    setNames(as.list(vars), rep("vars", length(vars)))
  )

  resp <- GET(base_url, query = query_list)

  if (http_error(resp)) {
    cat("\nFAILED:", station, year, sprintf("%02d", m), "\n")
    cat(content(resp, "text"), "\n")
    next
  }

  out_file <- file.path(out_dir, sprintf("KBKL_%d_%02d_raw.csv", year, m))
  writeBin(content(resp, "raw"), out_file)

  cat("Saved:", out_file, "\n")
}

