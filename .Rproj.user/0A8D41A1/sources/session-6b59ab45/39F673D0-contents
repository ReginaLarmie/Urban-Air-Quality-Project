```{r fig.width=7, fig.height=6}

library(openair)
library(dplyr)

# Build the wind-rose
met_wr <- met_2024 %>%
  transmute(
    date = as.POSIXct(t30, tz = "UTC"),
    ws = wind_speed_kn * 0.514444,   # knots -> m/s
    wd = wind_dir_deg
  ) %>%
  filter(!is.na(ws), !is.na(wd))

windRose(
  met_wr,
  ws = "ws",
  wd = "wd",
  angle = 30,
  breaks = c(0, 1, 3, 5, 8, 12, 20),
  key.position = "right",
  paddle = FALSE,
  main = "Cleveland (KCLE) Annual Wind Rose – 2024"
)

# Save a PDF
pdf("KCLE_Annual_WindRose_2024.pdf", width = 8.5, height = 7.5)

windRose(
  met_wr,
  ws = "ws",
  wd = "wd",
  angle = 30,                          # 12 direction bins
  breaks = c(0, 1, 3, 5, 8, 12, 20),    # match Jerry's bins
  key.position = "right",              # legend on the right
  paddle = FALSE,
  main = "Cleveland (KCLE) Annual Wind Rose \u2013 2024"
)

dev.off()


```
