# ---- Packages ----

library(riem)
library(readr)

# ---- Settings ----
stations   <- c("KCLE", "KBKL", "KCGF")
start_date <- "2023-01-01"
end_date   <- "2023-12-25"

raw_dir <- "data_raw_iem"
if (!dir.exists(raw_dir)) dir.create(raw_dir, recursive = TRUE)

# ---- Download + save each station separately ----
for (stn in stations) {

  rds_file <- file.path(
    raw_dir,
    sprintf("raw_%s_%s_to_%s.rds", stn, start_date, end_date)
  )

  csv_file <- file.path(
    raw_dir,
    sprintf("raw_%s_%s_to_%s.csv", stn, start_date, end_date)
  )

  # Skip download if already saved
  if (file.exists(rds_file)) {
    message("Already exists, skipping: ", stn)
    next
  }

  message("Downloading raw hourly data for ", stn, " ...")

  raw_df <- riem_measures(
    station    = stn,
    date_start = start_date,
    date_end   = end_date
  )

  # Save raw outputs
  saveRDS(raw_df, rds_file)
  write_csv(raw_df, csv_file)

  message("Saved files for ", stn)
}
