)

summary_tbl <- lapply(names(files), function(nm) {
  df <- read_csv(files[[nm]], show_col_types = FALSE)
  data.frame(
    station = nm,
    rows = nrow(df),
    start = min(df$datetime_utc, na.rm = TRUE),
    end   = max(df$datetime_utc, na.rm = TRUE)
  )
}) %>% bind_rows()

