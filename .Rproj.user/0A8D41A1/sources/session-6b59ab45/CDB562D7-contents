# Load necessary libraries
library(dplyr)
library(geosphere)

# STEP 1: Create a table of EPA sites with known coordinates
epa_sites <- tibble::tibble(
  epa_site_number = c("0034", "0038", "0045", "0060", "0065", "0073"),
  epa_site_name = c("Site A", "Site B", "Site C", "Site D", "Site E", "Site F"),
  lat_epa = c(41.476985, 41.49409, 41.47473, 41.46274, 41.50541, 41.49212),
  lon_epa = c(-81.682376, -81.70976, -81.72846, -81.65997, -81.66791, -81.67856)
)

# STEP 2: Create a new table of distances between each EPA site and all CinC devices
epa_to_cinc <- epa_sites %>%
  rowwise() %>%
  mutate(nearest = list({
    # For each EPA site, compute distance to each CinC location
    distances <- geosphere::distHaversine(
      matrix(c(lon_epa, lat_epa), ncol = 2),
      matrix(c(CinC_locations$longitude, CinC_locations$latitude), ncol = 2)
    )
    
    # Find index of the closest CinC device
    closest_index <- which.min(distances)
    
    # Extract the closest CinC device info
    CinC_locations[closest_index, ] %>%
      mutate(distance_m = distances[closest_index])
  })) %>%
  tidyr::unnest(cols = c(nearest))

# STEP 3: View the result
print(epa_to_cinc)
