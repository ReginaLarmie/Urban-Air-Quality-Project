# Build device pair distance table
loc_pairs <- expand.grid(
  device_number_1 = cinc_locations$device_number,
  device_number_2 = cinc_locations$device_number,
  stringsAsFactors = FALSE
) %>%
  left_join(cinc_locations, by = c("device_number_1" = "device_number")) %>%
  rename(lat1 = latitude, lon1 = longitude, loc1 = location_name) %>%
  left_join(cinc_locations, by = c("device_number_2" = "device_number")) %>%
  rename(lat2 = latitude, lon2 = longitude, loc2 = location_name) %>%
  mutate(distance_km = distHaversine(cbind(lon1, lat1), cbind(lon2, lat2))/1000)

# Compute pairwise R² among device daily series
calc_r2_tbl <- function(wide_df){
  devs <- setdiff(names(wide_df), "date")
  out <- list()
  for (i in seq_along(devs)) for (j in seq_along(devs)) {
    d1 <- devs[i]; d2 <- devs[j]
    x <- wide_df[[d1]]; y <- wide_df[[d2]]
    ok <- complete.cases(x, y)
    r2 <- if (sum(ok) > 2) summary(lm(y[ok] ~ x[ok]))$r.squared else NA_real_
    out[[length(out)+1]] <- tibble(device_number_1 = d1, device_number_2 = d2, R2 = r2)
  }
  bind_rows(out)
}

cinc_r2_tbl <- calc_r2_tbl(cinc_wide)
cinc_r2d <- loc_pairs %>%
  inner_join(cinc_r2_tbl, by = c("device_number_1","device_number_2")) %>%
  filter(device_number_1 != device_number_2) %>%
  rowwise() %>% mutate(pair_id = paste(sort(c(device_number_1, device_number_2)), collapse = "-")) %>%
  ungroup() %>% distinct(pair_id, .keep_all = TRUE)

pc <- ggplot(cinc_r2d, aes(distance_km, R2)) +
  geom_point(alpha = 0.7) +
  geom_smooth(method = "lm", se = FALSE, linetype = "dashed") +
  labs(title = "CLEANinCLE: Inter-device Agreement vs. Distance",
       x = "Distance between devices (km)", y = expression(R^2)) +
  theme_minimal()
