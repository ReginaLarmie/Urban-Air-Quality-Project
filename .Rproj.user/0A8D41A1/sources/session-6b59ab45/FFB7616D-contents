# Plots: CinC vs EPA (by EPA site), with common axes and R²

```{r cinc-epa, message=FALSE, warning=FALSE, fig.width=12, fig.height=10}
library(tidyverse)

pick_col <- function(df, patterns) {
  nm <- names(df)
  hit <- nm[Reduce(`|`, lapply(patterns, function(p) grepl(p, nm, ignore.case = TRUE)))]
  if (length(hit)) hit[1] else NA_character_
}

plot_cinc_vs_epa <- function(df, epa_col = NULL, cinc_col = NULL, site_col = NULL,
                             title_prefix, file_out, ncol = 2,
                             robust = TRUE, q = 0.99) {

  if (!nrow(df)) return(invisible(NULL))

  if (is.null(epa_col))  epa_col  <- pick_col(df, c("^pm25.*epa", "epa.*pm", "epa_.*pm", "pm.*_epa"))
  if (is.null(cinc_col)) cinc_col <- pick_col(df, c("^pm25.*cinc", "cinc.*pm", "pm.*_cinc"))
  if (is.null(site_col)) site_col <- pick_col(df, c("^epa_?site$", "^site$", "site_number", "epa_site"))

  needed <- c(epa_col, cinc_col, site_col)
  if (anyNA(needed)) return(invisible(NULL))

  d <- df %>%
    rename(pm_epa  = !!epa_col,
           pm_cinc = !!cinc_col,
           epa_site = !!site_col) %>%
    filter(is.finite(pm_epa), is.finite(pm_cinc)) %>%
    mutate(epa_site = as.character(epa_site))

  if (!nrow(d)) return(invisible(NULL))

  # ----- nicer shared limits -----
  if (robust) {
    lim_hi <- quantile(c(d$pm_epa, d$pm_cinc), probs = q, na.rm = TRUE)
  } else {
    lim_hi <- max(d$pm_epa, d$pm_cinc, na.rm = TRUE)
  }
  lim_hi <- max(5, ceiling(lim_hi/5)*5)
  lim <- c(0, lim_hi)

  # R^2 per site
  site_stats <- d %>%
    group_by(epa_site) %>%
    summarise(n = n(),
              r2 = ifelse(n > 2, summary(lm(pm_cinc ~ pm_epa))$r.squared, NA_real_),
              .groups = "drop")

  df_lab <- site_stats %>%
    mutate(label = paste0("R² = ", ifelse(is.na(r2), "NA", sprintf("%.2f", r2))),
           x = lim[1] + diff(lim)*0.03,
           y = lim[2] - diff(lim)*0.06)

  p <- ggplot(d, aes(pm_epa, pm_cinc)) +
    geom_point(alpha = 0.75, size = 2.1) +
    geom_smooth(method = "lm", se = FALSE, linewidth = 1.0, color = "steelblue") +
    geom_abline(slope = 1, intercept = 0, linetype = "dashed", color = "gray40") +
    coord_equal(xlim = lim, ylim = lim, expand = FALSE) +
    facet_wrap(~ epa_site, ncol = ncol) +
    geom_text(data = df_lab, aes(x = x, y = y, label = label),
              inherit.aes = FALSE, hjust = 0, vjust = 1, size = 4) +
    labs(
      title = title_prefix,
      x = "EPA PM2.5 (µg/m³)",
      y = "CLEANinCLE PM2.5 (µg/m³)"
    ) +
    scale_x_continuous(breaks = scales::pretty_breaks(6)) +
    scale_y_continuous(breaks = scales::pretty_breaks(6)) +
    theme_minimal(base_size = 16) +
    theme(
      plot.title = element_text(face = "bold", size = 18, hjust = 0.02),
      strip.text = element_text(face = "bold", size = 16),
      axis.title = element_text(size = 16),
      axis.text  = element_text(size = 12),
      panel.grid.minor = element_blank()
    )

  if (!dir.exists("figs")) dir.create("figs", recursive = TRUE)
  ggsave(file_out, p, width = 13, height = 10, dpi = 320)
  p
}

