library(tidyverse)

# Helper to find columns by pattern (works with your existing joins)
pick_col <- function(df, patterns) {
  nm <- names(df)
  hit <- nm[Reduce(`|`, lapply(patterns, function(p) grepl(p, nm, ignore.case = TRUE)))]
  if (length(hit)) hit[1] else NA_character_
}

# Build the per-point table used in the scatterplots and per-site stats; write CSVs
make_xy_tables <- function(df, label){
  if (!nrow(df)) return(invisible(NULL))

  # Detect the relevant columns (works for all three data frames you made)
  col_epa  <- pick_col(df, c("^pm25.*epa", "epa.*pm", "epa_.*pm", "pm.*_epa"))
  col_cinc <- pick_col(df, c("^pm25.*cinc", "cinc.*pm", "pm.*_cinc"))
  col_site <- pick_col(df, c("^epa_?site$", "^site$", "site_number", "epa_site"))
  col_date <- pick_col(df, c("^date$", "^Date$"))

  stopifnot(!is.na(col_epa), !is.na(col_cinc), !is.na(col_site), !is.na(col_date))

  # Exact point pairs used in each panel
  xy_tbl <- df %>%
    transmute(
      Date     = as.Date(.data[[col_date]]),
      EPA_Site = as.character(.data[[col_site]]),
      PM_EPA   = as.numeric(.data[[col_epa]]),
      PM_CinC  = as.numeric(.data[[col_cinc]])
    ) %>%
    filter(is.finite(PM_EPA), is.finite(PM_CinC)) %>%
    arrange(EPA_Site, Date)

  # Per-site regression summary (same model the plot uses)
  stats_tbl <- xy_tbl %>%
    group_by(EPA_Site) %>%
    summarise(
      n        = n(),
      slope    = if (n() > 2) coef(lm(PM_CinC ~ PM_EPA))[2] else NA_real_,
      intercept= if (n() > 2) coef(lm(PM_CinC ~ PM_EPA))[1] else NA_real_,
      r2       = if (n() > 2) summary(lm(PM_CinC ~ PM_EPA))$r.squared else NA_real_,
      pm_epa_min = min(PM_EPA,  na.rm = TRUE),
      pm_epa_max = max(PM_EPA,  na.rm = TRUE),
      pm_cinc_min= min(PM_CinC, na.rm = TRUE),
      pm_cinc_max= max(PM_CinC, na.rm = TRUE),
      .groups  = "drop"
    ) %>%
    mutate(eq_label = ifelse(is.finite(r2),
                             sprintf("y = %.2fx %+.2f; R² = %.2f", slope, intercept, r2),
                             "n < 3"))

  # Write CSVs
  dir.create("tables", showWarnings = FALSE, recursive = TRUE)
  write_csv(xy_tbl,    file.path("tables", paste0("cinc_epa_xy_points_", label, ".csv")))
  write_csv(stats_tbl, file.path("tables", paste0("cinc_epa_site_stats_", label, ".csv")))

  # (Optional) also write one CSV per site with the point pairs
  xy_split <- split(xy_tbl, xy_tbl$EPA_Site)
  purrr::iwalk(xy_split, ~ write_csv(.x, file.path("tables",
                       paste0("cinc_epa_xy_points_", label, "_site_", .y, ".csv"))))

  list(points = xy_tbl, stats = stats_tbl)
