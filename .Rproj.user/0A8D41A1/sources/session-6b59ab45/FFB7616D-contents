  epa_sites <- bind_rows(
    epa_sites,
    tibble(
      longitude = -81.6531,   # <-- replace with your exact 0073 longitude if different
      latitude  =  41.5046,   # <-- replace with your exact 0073 latitude  if different
      type      = factor("EPA AQS Sites", levels = legend_order),
      label_txt = "0073"
    )
  )
}

# ---- Plot ----
p <- ggplot() +
  geom_sf(data = target_counties, aes(fill = fill_color), color = "black", show.legend = FALSE) +
  geom_sf(data = lake_erie, fill = "#d9edff", color = NA, show.legend = FALSE) +

  # EPA AQS Sites (red dots)
  geom_point(
    data = epa_sites, aes(x = longitude, y = latitude, color = type),
    shape = 16, size = 2, show.legend = TRUE
  ) +

  # CLEANinCLE Sites (blue X)
  geom_point(
    data = cleanincle_sites, aes(x = longitude, y = latitude, color = type),
    shape = 4, size = 2, stroke = 1, show.legend = TRUE
  ) +

  # Cleveland Boundary — mapped only by color (no shape!)
  geom_sf(data = cleveland_land, aes(color = type),
          linetype = 1, linewidth = 1, fill = NA, show.legend = TRUE) +

  # Labels (map text)
  geom_text(data = map_labels, aes(x = longitude, y = latitude, label = label),
            color = "black", size = 5, fontface = "italic") +

  # **EPA site number labels** (non-overlapping)
  geom_text_repel(
    data = epa_sites, aes(x = longitude, y = latitude, label = label_txt),
    seed = 123, size = 3.6, fontface = "bold", color = "black",
    box.padding = 0.25, point.padding = 0.25, min.segment.length = 0,
    show.legend = FALSE
  ) +

  # Color controls
  scale_color_manual(
    name = "Legend",
    values = c("EPA AQS Sites" = "red",
               "CLEANinCLE Sites" = "darkblue",
               "Cleveland Boundary" = "purple")
  ) +

  # Combine symbols in one legend
  guides(color = guide_legend(override.aes = list(
    shape = c(16, 4, NA),
    linetype = c(0, 0, 1),
    size = c(2, 2, 1)
  ))) +

  scale_fill_identity() +
  coord_sf(xlim = c(-82.1, -81.3), ylim = c(41.27, 41.65)) +
  theme_minimal() +
  theme(
    panel.grid       = element_blank(),
    panel.background = element_rect(fill = "white", color = NA),
    axis.text        = element_blank(),
    axis.ticks       = element_blank(),
    axis.title       = element_blank()
  )

# Save
ggsave("map_cleveland.pdf", p, width = 8, height = 6, units = "in")
ggsave("map_cleveland.png", p, width = 8, height = 6, units = "in", dpi = 320)

