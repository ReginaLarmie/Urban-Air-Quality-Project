# EPA pairwise comparison matrices
```{r epa-6x6-filter-grid, fig.width=22, fig.height=22, echo=FALSE, message=FALSE, warning=FALSE}
plot_matrix_pairs <- function(wide_df, axis_min = 0, axis_max = 35, file_out = NULL, title = ""){
  site_names <- sort(setdiff(names(wide_df), "Date"))
  n_sites <- length(site_names)
  mats <- vector("list", n_sites * n_sites)

  for (i in seq_len(n_sites)) {
    for (j in seq_len(n_sites)) {
      x_site <- site_names[j]
      y_site <- site_names[i]
      idx <- (i - 1) * n_sites + j

      dfp <- wide_df %>%
        select(x = all_of(x_site), y = all_of(y_site)) %>%
        filter(!is.na(x) & !is.na(y))

      if (nrow(dfp) > 2) {
        fit <- lm(y ~ x, data = dfp)
        r2 <- round(summary(fit)$r.squared, 2)
        slope <- round(coef(fit)[2], 2)
        intercept <- round(coef(fit)[1], 2)
        label <- paste0("y = ", slope, "x + ", intercept, "\nR² = ", r2)
      } else {
        label <- "Insufficient data"
      }

      mats[[idx]] <- ggplot(dfp, aes(x, y)) +
        geom_point(alpha = 0.7, size = 1.6) +
        geom_smooth(method = "lm", se = FALSE, linewidth = 0.7) +
        geom_abline(slope = 1, intercept = 0, linetype = "dashed") +
        coord_fixed(xlim = c(axis_min, axis_max), ylim = c(axis_min, axis_max)) +
        labs(x = paste("Site", x_site), y = paste("Site", y_site)) +
        annotate("text", x = axis_min + 1, y = axis_max - 1,
                 label = label, hjust = 0, vjust = 1, size = 3.2) +
        theme_minimal(base_size = 11)
    }
  }

  g <- gridExtra::grid.arrange(grobs = mats, ncol = n_sites, nrow = n_sites,
                               top = grid::textGrob(title, gp = grid::gpar(fontsize = 14, fontface = "bold")))
  if (!is.null(file_out)) ggsave(file_out, g, width = 14, height = 14, dpi = 300)
  g
}

