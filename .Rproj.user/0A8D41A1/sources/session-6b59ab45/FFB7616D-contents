  select(device_number, device_eui, location_name, latitude, longitude) %>%
  distinct()

# Daily avg per device
cinc_daily <- cinc_clean %>%
  group_by(device_number, date) %>%
  summarise(pm25 = mean(pm25, na.rm = TRUE), .groups = "drop")

