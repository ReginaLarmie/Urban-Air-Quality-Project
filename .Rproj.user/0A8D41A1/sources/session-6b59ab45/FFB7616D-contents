library(tidyverse)

pick_col <- function(df, patterns) {
  nm <- names(df)
  hit <- nm[Reduce(`|`, lapply(patterns, function(p) grepl(p, nm, ignore.case = TRUE)))]
  if (length(hit)) hit[1] else NA_character_
}

# Make one export table from a CinC-vs-EPA data.frame
make_export_table <- function(df, robust = TRUE, q = 0.99) {
  if (!nrow(df)) return(tibble())

  # Auto-detect columns (EPA, CinC, Site, Date)
  epa_col  <- pick_col(df, c("^pm25.*epa", "epa.*pm", "epa_.*pm", "pm.*_epa"))
  cinc_col <- pick_col(df, c("^pm25.*cinc", "cinc.*pm", "pm.*_cinc"))
  site_col <- pick_col(df, c("^epa_?site$", "^site$", "site_number", "epa_site"))
  date_col <- pick_col(df, c("^date$", "date_local", "Date", "datetime"))

  #if any are missing, return empty tibble
  if (anyNA(c(epa_col, cinc_col, site_col))) return(tibble())

  d <- df %>%
    rename(pm_epa  = !!epa_col,
           pm_cinc = !!cinc_col,
           epa_site = !!site_col) %>%
    { if (!is.na(date_col)) rename(., Date = !!date_col) else mutate(., Date = as.Date(NA)) } %>%
    filter(is.finite(pm_epa), is.finite(pm_cinc)) %>%
    mutate(epa_site = as.character(epa_site))

  if (!nrow(d)) return(tibble())

  # Shared axis limits (same logic as your plot)
  lim_hi <- if (robust) quantile(c(d$pm_epa, d$pm_cinc), probs = q, na.rm = TRUE)
            else max(d$pm_epa, d$pm_cinc, na.rm = TRUE)
  lim_hi <- max(5, ceiling(lim_hi/5)*5)
  lims   <- c(0, lim_hi)

  # Per-site regression stats
  stats <- d %>%
    group_by(epa_site) %>%
    summarise(
      n = n(),
      slope     = if (n() > 2) coef(lm(pm_cinc ~ pm_epa))[2] else NA_real_,
      intercept = if (n() > 2) coef(lm(pm_cinc ~ pm_epa))[1] else NA_real_,
      r2        = if (n() > 2) summary(lm(pm_cinc ~ pm_epa))$r.squared else NA_real_,
      min_epa   = min(pm_epa,  na.rm = TRUE),
      max_epa   = max(pm_epa,  na.rm = TRUE),
      min_cinc  = min(pm_cinc, na.rm = TRUE),
      max_cinc  = max(pm_cinc, na.rm = TRUE),
      .groups = "drop"
    ) %>%
    mutate(
      eqn_label = ifelse(is.finite(r2),
                         sprintf("y = %.2fx %+ .2f", slope, intercept),
                         NA_character_),
      r2_label  = ifelse(is.finite(r2), sprintf("R² = %.2f", r2), NA_character_),
      axis_min  = lims[1],
      axis_max  = lims[2]
    )

  # Point-level table joined with per-site stats and axes
  out <- d %>%
    select(Date, epa_site, pm_epa, pm_cinc) %>%
    arrange(epa_site, Date) %>%
    left_join(stats, by = "epa_site")

  out
}

