# Helper to read one site file
read_epa_site <- function(site){
  f <- sprintf("epa_pm25_site_%s.csv", site)
  stopifnot(file.exists(f))
  df <- read_csv(f, show_col_types = FALSE)
  df <- df %>% mutate(site_number = site)
  df
